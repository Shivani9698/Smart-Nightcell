#ifndef INC_TEMP_HUMIDITY_SENSOR_H_
#define INC_TEMP_HUMIDITY_SENSOR_H_



#include <stdint.h>
#include "gpio.h"




#define USE_ONBOARD_SHTC3_SENSOR									0
#define USE_DS18B20_PROBE_SENSOR									1
#define USE_SHT40_PROBE_SENSOR										0


#define ONBOARD_SHTC3_SENSOR_CHIP_ADDRESS							0xE0



#define SHT40_PROBE_SENSOR_CHIP_ADDRESS								0x44
#define SHT40_ADDR_WRITE (SHT40_PROBE_SENSOR_CHIP_ADDRESS << 1)
#define SHT40_ADDR_READ  (SHT40_PROBE_SENSOR_CHIP_ADDRESS << 1)
#define SHT40_PROBE_SENSOR_MEASUREMENT_DELAY_MS 					10


extern TIM_HandleTypeDef htim2;


extern char flash_storage_buffer[32];



void read_humidity_and_temperature(int16_t *temp, uint8_t *humidity);
void set_pin_input(GPIO_TypeDef *GPIOx, uint16_t GPIO_Pin);
void set_pin_output(GPIO_TypeDef *GPIOx, uint16_t GPIO_Pin);
void delay_us(uint32_t time);


uint8_t ds18b20_start(void);
uint8_t ds18b20_read(void);
void ds18b20_write(uint8_t data);







#endif /* INC_TEMP_HUMIDITY_SENSOR_H_ */
