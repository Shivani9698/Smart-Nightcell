void cellular::turn_on_with_power_key(void)
{
	lte.pwrkey_gpio.on();
	osDelay(POWER_KEY_ON_PULSE_DELAY);
	lte.pwrkey_gpio.off();
	osDelay(POST_POWER_KEY_START_UP_DELAY);
}


void cellular::turn_off_with_power_key(void)
{
	lte.pwrkey_gpio.on();
	osDelay(POWER_KEY_OFF_PULSE_DELAY);
	lte.pwrkey_gpio.off();
	osDelay(POST_POWER_KEY_SHUT_DOWN_DELAY);
}


void cellular::reset(void)
{
	osDelay(200);
	lte.reset_gpio.on();
	osDelay(RESET_PULSE_DELAY);
	lte.reset_gpio.off();
	osDelay(POST_RESET_START_UP_DELAY);
}


void cellular::restart(void)
{
	reset();
	turn_on_with_power_key();
	deinitialise();
	initialise();

	attention();
	lte.echo_off();
	lte.echo_off();
	lte.echo_off();

	lte.get_imei();
	lte.get_sim_ccid();

	lte.set_network_scan_mode();
	lte.set_apn_settings();
}


