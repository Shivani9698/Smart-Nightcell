void cellular::send_command_and_wait_for_multi_line_response(char * command, uint32_t time_out)
{
	cellular_command_response = invalid_result;

	initialise();

	osDelay(100);

	lte.rx_counter = 0;

	memset(lte.downlink_data_buffer, 0, sizeof(lte.downlink_data_buffer));
	memset(lte.downlink_processing_buffer, 0, sizeof(lte.downlink_processing_buffer));


	lte.multi_line_response = 1;

	uint32_t prev_time_in_millisec = HAL_GetTick();
	this->printf("%s", command);
	uint32_t current_time_in_millisec = HAL_GetTick();

	while((cellular_command_response == invalid_result) && ((current_time_in_millisec - prev_time_in_millisec) < time_out))
	{
		current_time_in_millisec = HAL_GetTick();
		osDelay(10);
	}

	lte.multi_line_response = 0;
}


uint8_t cellular::process_imei_number(void)
{
	uint8_t result = 0;
	uint8_t i = 0;

	char *token = strtok((char *)downlink_processing_buffer, " \"\r\n");

	while(token != NULL)
	{
        i++;

        if (2 == i)
        {
 		   sprintf(write_device_info.sim_imei_number, "%s", token);
 		   debug.printf("IMEI Number: %s\r\n" , write_device_info.sim_imei_number);

 		   write_device_info.update();
 		   osDelay(500);
 		   read_device_info.get();

 		   result = 1;
        }

        token = strtok(NULL, " \"\r\n");
	}

	return result;
}


uint8_t cellular::process_sim_ccid_number(void)
{
	uint8_t result = 0;
	uint8_t i = 0;

	char *token = strtok((char *)downlink_processing_buffer, " :\"\r\n");

	while(token != NULL)
	{
        i++;

        if (2 == i)
        {
 		   sprintf(write_device_info.sim_ccid_number, "%s", token);
 		   debug.printf("SIM CCID: %s\r\n" , write_device_info.sim_ccid_number);

 		   write_device_info.update();
 		   osDelay(500);
 		   read_device_info.get();

 		   result = 1;
        }

        token = strtok(NULL, " :\"\r\n");
	}

	return result;
}



uint8_t cellular::process_qcsq(void)
{
	uint8_t result = 0;
	uint8_t csq_index = 0;

	char * token = strtok((char *)downlink_processing_buffer, "+QCSQ: ,\r\n");
	{
		while(token != NULL)
		{
			csq_index++;

			if (csq_index == 2)
			{
				signal_strength = atoi(token);
			}

			else if(csq_index == 3)
			{
				received_signal_power =  atoi(token);
			}

			else if(csq_index == 4)
			{
				channel_snr =  atoi(token);
			}

			else if(csq_index == 5)
			{
				received_signal_quality =  atoi(token);

				result = 1;
			}

			token = strtok(NULL, "+QCSQ: ,\r\n");
		}
	}

	return result;
}



uint8_t cellular::process_time_frame_and_get_date_time(void)
{
	 uint8_t result = 0;

	  if((downlink_processing_buffer[10] == '/') && (downlink_processing_buffer[13] == '/') && (downlink_processing_buffer[16] == ',')
			  && (downlink_processing_buffer[19] == ':') && (downlink_processing_buffer[22] == ':') && (downlink_processing_buffer[25] == '+'))
	  {
		  uint8_t index = 0;
		  char* token = strtok((char *)downlink_processing_buffer, "+CCLK: /\",");

		  while (token != NULL)
		  {
				index++;

				if(index == 1)
				{
					current_date_time.Year = atoi(token);
					current_date_time.year = 2000 + current_date_time.Year;
				}
				else  if(index == 2)
				{
					current_date_time.Month = atoi(token);
				}
				else  if(index == 3)
				{
					current_date_time.Date = atoi(token);
				}
				else  if(index == 4)
				{
					current_date_time.Hours = atoi(token);
				}
				else  if(index == 5)
				{
					current_date_time.Minutes = atoi(token);
				}
				else  if(index == 6)
				{
					current_date_time.Seconds = atoi(token);
				}

				token = strtok(NULL, "+CCLK: /\",");
		  }

		  debug.printf("Year: %d, Month: %d, Date: %d, Hours: %d, Minutes: %d, Seconds: %d\r\n", current_date_time.Year,
				  current_date_time.Month, current_date_time.Date, current_date_time.Hours, current_date_time.Minutes,
				  current_date_time.Seconds);

		  if((current_date_time.Year >= 23) && (current_date_time.Year < 40))
		  {
			  rtc.date_time_saved = 1;
			  rtc.set_date_time(current_date_time);
			  result = 1;
		  }
	  }

	  return result;
}



