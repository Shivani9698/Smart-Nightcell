void cellular::list_UFS_files_in_module_and_save_to_ram(void)
{
   char * token = strtok((char *)lte.downlink_processing_buffer, "+QFLST: \" , \r\nOK");

   int i = 0, j = 0;

   while(token != NULL)
   {
        if((i % 2) == 0)
       {
           sprintf(list_files[j].filename, "%s", token);
       }
       else if ((i % 2) == 1)
       {
          list_files[j].size = atoi(token);

          j++;
       }

       token = strtok(NULL,"+QFLST: \" , \r\nOK");
       i++;
   }

   for (int i = 0 ; i < 3 ; i++)
   {
       debug.printf("%s:%d\r\n", list_files[i].filename, list_files[i].size);
   }
}


uint8_t cellular::list_all_files_in_UFS(void)
{
	char command[128] = {'\0'};

	sprintf(command, "AT+QFLST=\"*\"\r\n");

	send_command_and_wait_for_multi_line_response(command, 5000);

	memset(lte.downlink_processing_buffer, 0, sizeof(lte.downlink_processing_buffer));
	memcpy(lte.downlink_processing_buffer, lte.downlink_data_buffer, lte.rx_counter);

	lte.rx_counter = 0;

	debug.printf("Files List:\r\n");
	debug.printf("%s\r\n", downlink_processing_buffer);

	list_UFS_files_in_module_and_save_to_ram();
}


