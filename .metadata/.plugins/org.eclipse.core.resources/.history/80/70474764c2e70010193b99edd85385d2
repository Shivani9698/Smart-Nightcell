uint8_t cellular::get_network_registartion_status(void)
{
	uint8_t count = 0;
	uint8_t result = 0;

	do
	{
		if((count % 10) == 0)
		{
			deinitialise();
			initialise();
			osDelay(100);
		}

		send_command_and_wait_for_response((char *)"AT+QCSQ\r\n", 1000);
		osDelay(500);
		send_command_and_wait_for_response((char *)"AT+CGREG?\r\n", 1000); // TODO: check if location are code, cell-id info needs to be fetched
		osDelay(500);

		count++;

	}while((network_registraion_status != 1) && (count < NUMBER_OF_NETWORK_REGISTRATION_RETRIES));

	if((network_registraion_status == 1) && (count < NUMBER_OF_NETWORK_REGISTRATION_RETRIES))
	{
		result = 1;
	}

	else if(count == NUMBER_OF_NETWORK_REGISTRATION_RETRIES)
	{
		result = 0;
	}

	return result;
}


