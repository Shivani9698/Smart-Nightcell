            	{
            		return res;
            	}
            }
        }

        line = strtok_r(NULL, "\r\n", &saveptr);
    }

    return res;
}


uint8_t cellular::process_https_response_and_fetch_lat_long_coordinates(char* latitude, char* longitude, int* accuracy, uint16_t* no_of_entities)
{
	uint8_t result = 0;
	uint8_t index = 0;

	DynamicJsonDocument doc(256);

	char *token = strtok((char *)downlink_processing_buffer, " \r\n");

	while (token != NULL)
	{
		index++;

		if (strstr(token, "location") != NULL)
		{
			DeserializationError error = deserializeJson(doc, token);

			if (!error)
			{
				double location_lat = doc["location"]["lat"]; // 22.4767251
				double location_lng = doc["location"]["lng"]; // 70.0669179

				int acc = doc["accuracy"]; // 2352

				if (location_lat && location_lng && accuracy)
				{
					sprintf(latitude, "%lf", location_lat);
					sprintf(longitude, "%lf", location_lng);

					*accuracy = acc;

					*no_of_entities = neighbour_cell_count + 1;

					debug.printf("latitude: %s\r\n", latitude);
					debug.printf("longitude: %s\r\n", longitude);
					debug.printf("precision: %d\r\n", *accuracy);


					result = 1;

					break;
				}
			}
		}

		token = strtok(NULL, " \r\n");
	}

	return result;
}




