uint8_t cellular::process_cellular_data(void)
{
	uint8_t res = 0;
	cellular_command_response = invalid_result;

	if ((strstr((char *)downlink_processing_buffer, "RDY") != NULL) || (strstr((char *)downlink_processing_buffer, "+QIND: SMS DONE") != NULL) ||
			(strstr((char *)downlink_processing_buffer, "+QIND: PB DONE") != NULL))
	{
		cellular_command_response = cellular_bootup;
	}

	else if ((strstr((char *)downlink_processing_buffer, "+CME ERROR: 516") != NULL) || ((strstr((char *)downlink_processing_buffer, "+CME ERROR: 505") != NULL)))
	{
		cellular_command_response = gnss_gps_location_failed;
	}

	else if ((strstr((char *)downlink_processing_buffer, "ERROR") != NULL) || (strstr((char *)downlink_processing_buffer, "+CME ERROR:") != NULL))
	{
		cellular_command_response = error_result;
	}

	else if(strstr((char *)downlink_processing_buffer, "CONNECT") != NULL)
	{
		cellular_command_response = connect;
	}

	else if (strstr((char *)downlink_processing_buffer, "+CPIN: READY") != NULL)
	{
		cellular_command_response = ready_received;
	}

	else if (strstr((char *)downlink_processing_buffer, "+CGSN:") != NULL)
	{
		uint8_t res = process_imei_number();

		if (1 == res)
		{
			cellular_command_response = imei_number_received;
		}
	}

	else if (strstr((char *)downlink_processing_buffer, "+QCCID:") != NULL)
	{
		process_sim_ccid_number();

		ready_status = 1;
		cellular_command_response = sim_ccid_received;
	}

	else if(strstr((char *)downlink_processing_buffer, "AT+QICSGP=1,3,\"jionet\"") != NULL)
	{

	}

	else if(strstr((char *)downlink_processing_buffer, "+QIACT: 1,1") != NULL)
	{
		cellular_command_response = internet_activated;
	}

	else if(strstr((char *)downlink_processing_buffer, "QCSQ: ") != NULL)
	{
		uint8_t res = process_qcsq();

		if (1 == res)
		{
			debug.printf("signal_strength: %d, received_signal_power: %d, channel_snr: %d, received_signal_quality: %d\r\n",
					signal_strength, received_signal_power, channel_snr, received_signal_quality);

			cellular_command_response = qcsq_received;
		}
	}

	else if (((strstr((char *)downlink_processing_buffer, "+CGREG: 0,1") != NULL)) || (strstr((char *)downlink_processing_buffer, "+CGREG: 0,5") != NULL))
	{
		network_registraion_status = 1;
		cellular_command_response = network_registration_done;
	}

	else if(strstr((char *)downlink_processing_buffer, "+CCLK") != NULL)
	{
		uint8_t res = process_time_frame_and_get_date_time();

		if (1 == res)
		{
			if (1 == power_up)
			{
				write_device_info.device_start_time = rtc.get_time_in_utc();

				write_device_info.update();
				osDelay(100);
				read_device_info.get();

				power_up = 0;
			}

			time_status = 1;
			cellular_command_response = time_synchronised;
		}
	}

	else if(strstr((char *)downlink_processing_buffer, "+QMTOPEN: 0,0") != NULL)
	{
		mqtt_open_status = 1;
		cellular_command_response = mqtt_open_success;
	}

	else if (strstr((char *)downlink_processing_buffer, "+QMTOPEN: 0,") != NULL)
	{
		cellular_command_response = mqtt_open_fail;
	}

	else if(strstr((char *)downlink_processing_buffer, "+QMTCONN: 0,0,0") != NULL)
	{
		mqtt_connection_status = 1;
		cellular_command_response = mqtt_connection_success;
	}

	else if (strstr((char *)downlink_processing_buffer, "+QMTCONN: 0,0") != NULL)
	{
		cellular_command_response = mqtt_connection_fail;
	}

	else if(strstr((char *)downlink_processing_buffer, "+QMTSUB: 0") != NULL)
	{
		cellular_command_response = mqtt_subcription_received;
	}

	else if((strstr((char *)downlink_processing_buffer, "+QMTPUBEX: 0,0,0") != NULL) || (strstr((char *)downlink_processing_buffer, "+QMTPUBEX: 0,1,0") != NULL))
	{
		cellular_command_response = mqtt_publish_success;
	}

	else if(strstr((char *)downlink_processing_buffer, "+QMTRECV: ") != NULL)
	{
		debug.printf("Cellular RX Data: %s\r\n", downlink_processing_buffer);

		memset(downlink.processing_buffer, 0, sizeof(downlink.processing_buffer));
		sprintf(downlink.processing_buffer, "%s", strstr((char *)downlink_processing_buffer, "{"));


		cellular_command_response = incoming_data_received;

		downlink_semaphore.acquire(0);
		downlink_semaphore.release();
	}


	else if(strstr((char *)downlink_processing_buffer, "+QFUPL:") != NULL)
	{
		file_handle.check = 1;
		cellular_command_response = certificate_loaded;
	}

	else if (strstr((char *)downlink_processing_buffer, "+QGPSLOC:") != NULL)
	{
		debug.printf("Received GNSS/GPS Location Info: %s\r\n", downlink_processing_buffer);

		uint8_t res = process_gnss_gps_location_info();

		if (1 == res)
		{
			cellular_command_response = gnss_gps_location_received;

			gnss_gps_data_process_semaphore.acquire(0);
			gnss_gps_data_process_semaphore.release();
		}
	}

	else if(strstr((char *)downlink_processing_buffer, "OK") != NULL)
	{
		cellular_command_response = ok_result;
	}


	else if (strstr((char *)downlink_processing_buffer, "+QHTTPPOST: 0,200") != NULL)
	{
		cellular_command_response = http_post_success;
	}

	else if (strstr((char *)downlink_processing_buffer, "+QHTTPPOST: ") != NULL)
	{
		cellular_command_response = http_post_fail;
	}

	return res;
}




uint8_t clear_next_message_flags(void)
{
	uint8_t status = 0;

	if (1 == next_message.https_error_message)
	{
		next_message.https_error_message = 0;
	}

	else if (1 == next_message.start_up)
	{
		next_message.start_up = 0;
	}

	else if (1 == next_message.health)
	{
		next_message.health = 0;
	}

	else if (1 == next_message.set_config_ack)
	{
		next_message.set_config_ack = 0;

		status = 1;
	}

	else if (1 == next_message.get_config_ack)
	{
		next_message.get_config_ack = 0;
	}


	else if (1 == next_message.configure_apn_ack)
	{
		next_message.configure_apn_ack = 0;

		status = 1;
	}

	else if (1 == next_message.reboot_ack)
	{
		next_message.reboot_ack = 0;

		status = 1;
	}

	else if (1 == next_message.reset_to_factory_defaults_ack)
	{
		next_message.reset_to_factory_defaults_ack = 0;

		eeprom.write_byte(0xFE, START_ADDRESS_OF_NEW_EEPROM);

		status = 1;
	}

	else if (1 == next_message.turn_off_edge_device_ack)
	{
		next_message.turn_off_edge_device_ack = 0;

		peripherals.power_on_all_peripherals = 0;
	}

	else if (1 == next_message.update_geolocator_api_key_ack)
	{
		next_message.update_geolocator_api_key_ack = 0;
	}

	next_message.update();
	osDelay(100);
	next_message.get();

	return status;
}




void cellular_thread_task(void const * argument)
{
  /* USER CODE BEGIN cellular_thread_task */
	uint8_t result = 0;

	osDelay(5000);

  /* Infinite loop */
  for(;;)
  {
	  result = 0;

	  HAL_IWDG_Refresh(&hiwdg1);

	  if ((cellular_enable == read_device_info.communication_mode_enabled) && (1 == peripherals.power_on_all_peripherals))
	  {
		  if ((0 == lte.ready_status) && (0 == lte.network_registraion_status) && (0 == lte.time_status) &&
				  (0 == lte.mqtt_open_status) && (0 == lte.mqtt_connection_status))
		  {
			  lte.multi_line_response = 0;

			  lte.reset();
			  lte.turn_on_with_power_key();

			  osDelay(3000);

			  lte.initialise();
//			  osDelay(50);
			  osDelay(100);
			  lte.attention();
			  osDelay(50);
			  lte.echo_off();
			  osDelay(50);
			  lte.set_network_scan_mode();
			  osDelay(50);
//			  lte.query_module_status();
			  osDelay(100);

			  lte.get_imei();

			  memset(lte.downlink_processing_buffer, 0, sizeof(lte.downlink_processing_buffer));
			  memcpy(lte.downlink_processing_buffer, lte.downlink_data_buffer, lte.rx_counter);
			  lte.rx_counter = 0;

			  lte.process_cellular_data();

			  osDelay(50);

			  lte.get_sim_ccid();

			  memset(lte.downlink_processing_buffer, 0, sizeof(lte.downlink_processing_buffer));
			  memcpy(lte.downlink_processing_buffer, lte.downlink_data_buffer, lte.rx_counter);
			  lte.rx_counter = 0;

			  lte.process_cellular_data();
		  }

		  else if ((1 == lte.ready_status) && (0 == lte.network_registraion_status) && (0 == lte.time_status) &&
				  (0 == lte.mqtt_open_status) && (0 == lte.mqtt_connection_status))
		  {
			  result = lte.set_apn_settings();

			  osDelay(500);

			  if (1 == result)
			  {
				  result = lte.get_network_registartion_status();

				  if (1 == result)
				  {
					  debug.printf("Network Registration Success\r\n");
					  blue_led.on();
				  }

				  else
				  {
					  debug.printf("Network Registration Failed\r\n");

					  lte.clear_all_status_flags();

					  peripherals.start_application = 0;
				  }
			  }
			  else
			  {
				  debug.printf("Network Registration Failed\r\n");

				  lte.clear_all_status_flags();

				  peripherals.start_application = 0;
			  }
		  }

		  else if ((1 == lte.ready_status) && (1 == lte.network_registraion_status) && (0 == lte.time_status) &&
				  (0 == lte.mqtt_open_status) && (0 == lte.mqtt_connection_status))
		  {
			  result = lte.get_time_sychronised();

			  if (1 == result)
			  {
				  debug.printf("Time Sync Success: %ld\r\n", rtc.get_time_in_utc());

				  next_ephemeris_download_time = rtc.get_time_in_utc();
			  }
			  else
			  {
				  debug.printf("Time Sync Failed\r\n");

				  lte.clear_all_status_flags();

				  peripherals.start_application = 0;
			  }
		  }


		  else if ((1 == lte.ready_status) && (1 == lte.network_registraion_status) && (1 == lte.time_status) &&
				  (0 == lte.mqtt_open_status) && (0 == lte.mqtt_connection_status))
		  {
			  if (1 == cellular_mutex.lock(1000))
			  {
				  lte.init_ssl();

				  result = lte.open_mqtt_connection(read_device_info.mqtt_broker_endpoint, read_device_info.port_number);

				  if (1 == result)
				  {
					  debug.printf("Successfully opened MQTT Connection\r\n");

					  result = lte.connect_to_broker(read_device_info.access_token);

					  if (1 == result)
					  {
						  debug.printf("Successfully connected to MQTT Broker\r\n");

						  result = lte.subscribe(read_device_info.device_downlink_topic);

						  if (1 == result)
						  {
							  blue_led.toggle();

							  lte.error_counter = 0;

							  if (0 == peripherals.start_application)
							  {
								  peripherals.start_application = 1;
							  }

							  debug.printf("Successfully subscribed to topic: %s\r\n", read_device_info.device_downlink_topic);
						  }
					  }
					  else
					  {
						  debug.printf("Failed connecting to MQTT Broker\r\n");

						  lte.close_connection();

						  lte.clear_all_status_flags();

						  peripherals.start_application = 0;
					  }
				  }
				  else
				  {
					  debug.printf("Failed opening MQTT Connection\r\n");

					  lte.close_connection();

					  lte.clear_all_status_flags();

					  peripherals.start_application = 0;
				  }

				  cellular_mutex.unlock();
			  }
		  }


		  else if ((1 == lte.ready_status) && (1 == lte.network_registraion_status) && (1 == lte.time_status) &&
				  (1 == lte.mqtt_open_status) && (1 == lte.mqtt_connection_status))
		  {
			  blue_led.toggle();

			  if (1 == cellular_mutex.lock(1000))
			  {
				  uint16_t length = check_if_any_uplink_to_be_published(lte.uplink_message_buffer, sizeof(lte.uplink_message_buffer));

				  if (length > 0)
				  {
					  result = lte.publish(read_device_info.device_uplink_telemetry_topic, lte.uplink_message_buffer, length);

					  if (1 == result)
					  {
						  debug.printf("Successfully published data to topic: %s -> %s\r\n", read_device_info.device_uplink_telemetry_topic, lte.uplink_message_buffer);

						  lte.error_counter = 0;

						  uint8_t status = clear_next_message_flags();

						  if (1 == status)
						  {
							  osDelay(2000);
							  __disable_irq();

							  HAL_NVIC_SystemReset();
						  }
					  }

					  else
					  {
						  debug.printf("Failed to publish data\r\n");

						  lte.close_connection();

						  lte.clear_all_status_flags();

						  peripherals.start_application = 0;
					  }
				  }
				  cellular_mutex.unlock();
			  }
		  }

		  if ((1 == lte.ready_status) && (1 == lte.network_registraion_status) && (1 == lte.time_status) &&
				  (1 == lte.mqtt_open_status) && (1 == lte.mqtt_connection_status))
		  {
			  blue_led.toggle();

			  if (1 == cellular_mutex.lock(1000))
			  {
				  write_index = eeprom.read_int(START_ADDRESS_OF_WRITE_COUNTER_INDEX);
				  write_page_counter = eeprom.storage_counter_read(write_index);

				  read_index = eeprom.read_int(START_ADDRESS_OF_READ_COUNTER_INDEX);
				  read_page_counter = eeprom.reader_counter_read(read_index);

				  if(read_page_counter % FOUR_MILLION == 0)
				  {
					  read_index = read_page_counter / FOUR_MILLION;

					  eeprom.write_int(read_index , START_ADDRESS_OF_READ_COUNTER_INDEX);
				  }

				  if (read_page_counter < write_page_counter)
				  {
					  memset(&water_tank_read_data_buffer, 0, sizeof(water_tank_read_data_buffer));
					  nor.read_data_packets(water_tank_read_data_buffer);

					  memcpy(&water_tank_read_data, water_tank_read_data_buffer, sizeof(water_tank_read_data_buffer));

					  uint16_t length = serialize_water_tank_data_payload_packet(lte.uplink_message_buffer, sizeof(lte.uplink_message_buffer));

					  if (length > 0)
					  {
						  result = lte.publish(read_device_info.device_uplink_telemetry_topic, lte.uplink_message_buffer, length);

						  if (1 == result)
						  {
							  debug.printf("Successfully published data to topic: %s -> %s\r\n", read_device_info.device_uplink_telemetry_topic, lte.uplink_message_buffer);

							  lte.error_counter = 0;

							  read_page_counter++;
							  eeprom.reader_counter_write(read_page_counter, read_index);
						  }
					  }
				  }

				  cellular_mutex.unlock();
			  }
		  }
	  }

	  osDelay(1000);
  }
  /* USER CODE END cellular_thread_task */
}







void cellular_processing_task(void const * argument)
{
  /* USER CODE BEGIN cellular_processing_task */
  /* Infinite loop */
  for(;;)
  {
	  if (1 == cellular_isr_semaphore.acquire(1000))
	  {
		  lte.process_cellular_data();
	  }

	  else if (1 == cellular_manual_data_process_semaphore.acquire(1000))
	  {
		  lte.process_cellular_data();
	  }


	  if (cellular_bootup == cellular_command_response)
	  {
		  if (1 == peripherals.start_application)
		  {
			  lte.ready_status = 0;
			  lte.network_registraion_status = 0;
			  lte.time_status = 0;
			  lte.mqtt_open_status = 0;
			  lte.mqtt_connection_status = 0;
		  }

		  peripherals.start_application = 0;
	  }


	  if (error_result == cellular_command_response)
	  {
		  lte.error_counter++;

		  if (lte.error_counter >= 15)
		  {
			  debug.printf("Cellular Error Counter exceeded maximum limit, restarting the cellular module\r\n");

			  lte.error_counter = 0;

			  lte.close_connection();
			  lte.deinitialise();

			  lte.turn_off_with_power_key();

			  lte.ready_status = 0;
			  lte.network_registraion_status = 0;
			  lte.time_status = 0;
			  lte.mqtt_open_status = 0;
			  lte.mqtt_connection_status = 0;
		  }
	  }

	  osDelay(100);
  }
  /* USER CODE END cellular_processing_task */
}



void cellular::my_callback(UART_HandleTypeDef * uart)
{
	lte.rx_byte = lte.huart->Instance->RDR;

	if (0 == lte.multi_line_response)
	{
		if(lte.rx_counter >= (MAX_WIFI_BUFFER_SIZE - 4))
		{
			lte.rx_counter = 0;
		}

		if(lte.rx_byte == 0)
		{

		}

		if ((0 == lte.rx_counter) && (('\r' == lte.rx_byte) || ('\n' == lte.rx_byte)))
		{

		}

		else if(lte.rx_byte == '\n')
		{
			lte.downlink_data_buffer[lte.rx_counter++] = lte.rx_byte;
			lte.downlink_data_buffer[lte.rx_counter++] = '\0';

			if(lte.rx_counter > 6)
			{
				memset(lte.downlink_processing_buffer, 0, sizeof(lte.downlink_processing_buffer));
				memcpy(lte.downlink_processing_buffer, lte.downlink_data_buffer, lte.rx_counter);

				lte.rx_counter = 0;

				cellular_isr_semaphore.acquire(0);
				uint8_t res = cellular_isr_semaphore.release();
			}
			else
			{
				lte.rx_counter = 0;
			}

		}
		else
		{
			lte.downlink_data_buffer[lte.rx_counter++] = lte.rx_byte;
		}
	}

	else if (1 == lte.multi_line_response)
	{
		lte.downlink_data_buffer[lte.rx_counter++] = lte.rx_byte;

		if (lte.rx_counter >= 4)
		{
			if ((lte.rx_counter >= 6) && (lte.downlink_data_buffer[lte.rx_counter - 6] == '\r') && (lte.downlink_data_buffer[lte.rx_counter - 5] == '\n') &&
					(lte.downlink_data_buffer[lte.rx_counter - 4] == 'O') && (lte.downlink_data_buffer[lte.rx_counter - 3] == 'K') &&
					(lte.downlink_data_buffer[lte.rx_counter - 2] == '\r') && (lte.downlink_data_buffer[lte.rx_counter - 1] == '\n'))
			{
				lte.downlink_data_buffer[lte.rx_counter] = '\0';

				cellular_command_response = ok_result;
			}

	        else if ((lte.rx_counter >= 7) && (lte.downlink_data_buffer[lte.rx_counter - 7] == 'E') && (lte.downlink_data_buffer[lte.rx_counter - 6] == 'R') &&
	        		(lte.downlink_data_buffer[lte.rx_counter - 5] == 'R') && (lte.downlink_data_buffer[lte.rx_counter - 4] == 'O') &&
	                (lte.downlink_data_buffer[lte.rx_counter - 3] == 'R') && (lte.downlink_data_buffer[lte.rx_counter - 2] == '\r') &&
	                (lte.downlink_data_buffer[lte.rx_counter - 1] == '\n'))
	        {
	            lte.downlink_data_buffer[lte.rx_counter] = '\0';

	            cellular_command_response = error_result;
	        }

		    if (lte.rx_counter >= (MAX_WIFI_BUFFER_SIZE - 2))
		    {
		        lte.rx_counter = MAX_WIFI_BUFFER_SIZE - 2;
		        lte.multi_line_response = 0;

		        cellular_command_response = error_result;
		    }
		}
	}

	HAL_UART_Receive_IT(lte.huart, (uint8_t *)&lte.usart_rx_byte , 1);
}
