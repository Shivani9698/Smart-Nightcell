uint8_t cellular::publish(char * topic, char * data, uint16_t length)
{
	uint8_t result = 0;
	uint8_t count = 0;

	lte.printf("AT+QMTPUBEX=0,1,1,0,\"%s\",%d\r\n", topic, length);

	osDelay(100);

	lte.printf("%s\r\n", data);

	do
	{
		count++;
		send_command_and_wait_for_response((char *)"", 50);

	}while((cellular_command_response != mqtt_publish_success) && (count < 100));

	if ((count == 0) || (count >= 100))
	{
		result = 0;
	}
	else if(cellular_command_response == mqtt_publish_success)
	{
		result = 1;
	}

	return result;
}



