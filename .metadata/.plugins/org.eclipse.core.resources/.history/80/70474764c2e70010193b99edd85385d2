uint8_t cellular::open_mqtt_connection(char * end_point, int port_number)
{
    uint8_t count = 0;
    uint8_t result = 0;

	char command[256] = {'\0'};

    lte.deinitialise();
    lte.initialise();

	sprintf(command, "AT+QMTOPEN=0,\"%s\",%d\r\n", end_point, port_number);

	debug.printf("mqtt open command: %s\r\n", command);

	do
	{
		lte.close_connection();
		osDelay(500);
		send_command_and_wait_for_response(command, 20000);
		count++;
	}
	while((cellular_command_response != mqtt_open_success) && (count < MQTT_OPEN_RETRIES));

	if((count == MQTT_OPEN_RETRIES) && (cellular_command_response != mqtt_open_success))
	{
		result = 0;
	}
	else if (cellular_command_response == mqtt_open_success)
	{
		result = 1;
	}

	return result;
}


uint8_t cellular::connect_to_broker(char * access_token)
{
	uint8_t count = 0;
	uint8_t result = 0;

	char command[256] = {'\0'};

	sprintf(command, "AT+QMTCONN=0,\"%s\",\"%s\",\"\"\r\n", access_token, access_token);

	debug.printf("mqtt connect command: %s\r\n", command);

	if(mqtt_open_status == 1)
	{
		do
		{
			send_command_and_wait_for_response(command, 5000);
			count++;

			osDelay(1000);

		}while((cellular_command_response != mqtt_connection_success) && (count < MQTT_OPEN_RETRIES));
	}

	if((count == MQTT_OPEN_RETRIES) && (cellular_command_response != mqtt_connection_success))
	{
		result = 0;
	}
	else if(cellular_command_response == mqtt_connection_success)
	{
		result = 1;
	}

	return result;
}


