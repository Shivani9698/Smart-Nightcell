uint8_t cellular::process_neighbour_cell_information(void)
{
	uint8_t res = 0;
    neighbour_cell_count = 0;


    char *saveptr;
    char *line = strtok_r((char *)downlink_processing_buffer, "\r\n", &saveptr);


    while (line != NULL)
    {
#if	USE_BOTH_INTRA_AND_INTER_CELL_FOR_GEOLOCATION
        if (strstr(line, "+QENG:") && strstr(line, "neighbourcell"))
#endif
#if  USE_INTRA_CELL_FOR_GEOLOCATION
    	if (strstr(line, "+QENG:") && strstr(line, "neighbourcell") && strstr(line, "intra"))
#endif
        {
            res = process_single_neighbour_cell((uint8_t *)line);

            if ((1 == res) && (neighbour_cell_count < MAX_NEIGHBOUR_CELLS))
            {
            	neighbour_cell_count++;

