void cellular::send_command_and_wait_for_response(char * command,  uint32_t time_out)
{
	cellular_command_response = invalid_result;

	uint32_t prev_time_in_millisec = HAL_GetTick();
	printf("%s",command);
	uint32_t current_time_in_millisec = HAL_GetTick();

	while((cellular_command_response == invalid_result) && ((current_time_in_millisec - prev_time_in_millisec) < time_out))
	{
		current_time_in_millisec = HAL_GetTick();
		osDelay(10);
	}
}


void cellular::send_command_and_wait_for_OK_response(char * command,  uint32_t time_out)
{
	cellular_command_response = invalid_result;

	uint32_t prev_time_in_millisec = HAL_GetTick();
	this->printf("%s",command);
	uint32_t current_time_in_millisec = HAL_GetTick();

	while((cellular_command_response != ok_result) && (cellular_command_response == invalid_result) && ((current_time_in_millisec - prev_time_in_millisec) < time_out))
	{
		current_time_in_millisec = HAL_GetTick();
		osDelay(10);
	}
}


