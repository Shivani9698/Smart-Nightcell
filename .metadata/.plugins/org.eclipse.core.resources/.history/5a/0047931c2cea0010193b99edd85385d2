// Helper function to convert byte array to hex string

void bytes_to_hex_string(uint8_t* bytes, size_t len, char* output)
{
    for (size_t i = 0; i < len; i++) {
        sprintf(output + (i * 2), "%02X", bytes[i]);
    }
    output[len * 2] = '\0';
}

