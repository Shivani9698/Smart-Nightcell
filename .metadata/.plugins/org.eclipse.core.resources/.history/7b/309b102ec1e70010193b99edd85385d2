uint16_t nor_flash::read_non_volatile_config_register(void)
{
	uint8_t temp[2];
	uint16_t value;

	chip_enable();

	nor_write_byte(FLASH_INS_RDNVCR);
	temp[0] = nor_write_byte(DUMMY_BYTE);
	temp[1] = nor_write_byte(DUMMY_BYTE);

	chip_disable();

	value = (temp[0] << 8) | temp[1];
	debug.printf("Non Volatile Config Register: %x\r\n", value);

	return value;
}


