void nor_flash::erase_sub_subsector(uint32_t address)
{
	write_enable();
	chip_enable();

	nor_write_byte(FLASH_INS_SSE);
	nor_write_byte((address & ADDRESS_BMASK3) >> 24);
	nor_write_byte((address & ADDRESS_BMASK2) >> 16);
	nor_write_byte((address & ADDRESS_BMASK1) >> 8);
	nor_write_byte(address & ADDRESS_BMASK0);

	wait_for_oip_to_clear();

	chip_disable();
	write_disable();

	osDelay(2000);
}


uint8_t nor_flash::save_data_packets(char* data_buffer)
{
	uint8_t res = 0;

	write_index = eeprom.read_int(START_ADDRESS_OF_WRITE_COUNTER_INDEX);
	write_page_counter = eeprom.storage_counter_read(write_index);

	sector = (write_page_counter / MAX_SAMPLES_IN_A_SECTOR) %  NUMBER_OF_SECTORS;
	page = write_page_counter % MAX_SAMPLES_IN_A_SECTOR;
	address = (sector * SECTOR_SIZE) + (page * WRITE_SIZE);

	if(0 == (write_page_counter % MAX_SAMPLES_IN_A_SECTOR))
	{
//		eeprom.sector_write_byte(0, sector); // TODO: check if this is required as only 1 sector is availble in nor flash. Cross-check to be done

		if (1 == nor_mutex.lock(1000))
		{
			__disable_irq();
			nor.sector_erase(address);
			__enable_irq();

			nor_mutex.unlock();
		}
	}

	if (1 == nor_mutex.lock(1000))
	{
		__disable_irq();

		nor.page_write(address , &data_buffer[0], WRITE_SIZE);

		__enable_irq();

		nor_mutex.unlock();
	}

//	if(0 == (write_page_counter % MAX_SAMPLES_PER_SECTOR)) // TODO: check if this is required as only 1 sector is availble in nor flash. Cross-check to be done
//	{
//		eeprom.sector_write_byte(1, sector);
//	}

	write_page_counter++;

	if (0 == (write_page_counter % FOUR_MILLION))
	{
		write_index = write_page_counter / FOUR_MILLION;

		eeprom.write_int(write_index , START_ADDRESS_OF_WRITE_COUNTER_INDEX);
	}

	eeprom.storage_counter_write(write_page_counter, write_index);


	return res;
}


