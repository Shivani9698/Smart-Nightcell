void nor_flash::nor_transmit_byte(uint8_t data)
{
  this->spi_transmit(&data, 1);
}


uint8_t nor_flash::nor_write_byte(uint8_t data)
{
	uint8_t result;

	result = this->spi_transmit_receive_byte(data);

	return  result;
}


uint8_t nor_flash::nor_write_bytes(char * send_data, uint16_t length)
{
	uint8_t result;

	result = this->spi_transmit_bytes((uint8_t *)send_data,length);

	return  result;
}


uint8_t nor_flash::nor_write_read_bytes(char * send_data, char * read_data, uint16_t length)
{
	uint8_t result;

	result = this->spi_transmit_receive_bytes((uint8_t *)send_data, (uint8_t *)read_data, length);

	return  result;
}


void nor_flash::chip_enable(void)
{
	this->off();
}


void nor_flash::chip_disable(void)
{
	this->on();
}


void nor_flash::write_enable(void)
{
	chip_enable();
	nor_write_byte(FLASH_INS_WREN);
	chip_disable();
}

void nor_flash::write_disable(void)
{
	chip_enable();
	nor_write_byte(FLASH_INS_WRDI);
	chip_disable();
}


uint32_t nor_flash::read_id(void)
{
	uint32_t read_id = 0;
	uint8_t id[3];

	chip_enable();

	nor_write_byte(FLASH_INS_RDID);

	id[0] = nor_write_byte(DUMMY_BYTE);
	id[1] = nor_write_byte(DUMMY_BYTE);
	id[2] = nor_write_byte(DUMMY_BYTE);

	chip_disable();

	read_id = (uint32_t )((uint32_t )(id[0] << 16) | (uint32_t )(id[1] << 8) | (uint32_t )id[2]);

	return read_id;
}


void nor_flash::write_register(uint8_t register_address, uint8_t reg_value)
{
	write_enable();
	chip_enable();

	nor_write_byte(register_address);
	nor_write_byte(reg_value);

	chip_disable();
	write_disable();

	osDelay(WAIT_TIME);
}


void nor_flash::clear_register(uint8_t reg_address)
{
	write_enable();
	chip_enable();

	nor_write_byte(reg_address);

	chip_disable();
	write_disable();

	osDelay(WAIT_TIME);
}


uint8_t  nor_flash::read_register(uint8_t register_address)
{
	int counter = 0;
	uint8_t value;

	chip_enable();

	nor_write_byte(register_address);
	value = nor_write_byte(DUMMY_BYTE);

	chip_disable();

	while(counter < 100000)
	{
		counter++;
	}

	return value;
}


uint16_t nor_flash::read_novolatile_read_register(uint8_t register_address)
{
	uint16_t value;
	uint8_t temp[2] = {'\0'};

	chip_enable();

	nor_write_byte(register_address);
	temp[0] = nor_write_byte(DUMMY_BYTE);
	temp[1] = nor_write_byte(DUMMY_BYTE);

	value = (uint16_t )(temp[0] << 8) |(uint16_t ) temp[1];

	chip_disable();

	debug.printf("Register : %X Value %X\r\n", register_address, value);
	osDelay(10);

	return value;
}


void nor_flash::wait_for_oip_to_clear(void)
{
	uint8_t value = 0xFF;

	do
	{
		value = read_register(FLASH_INS_RDSR);

	}while((value & 0x01) == 0x01);
}


void nor_flash::reset(void)
{
	chip_enable();

	nor_write_byte(FLASH_INS_REN);

	chip_disable();

	wait_for_oip_to_clear();

	chip_enable();

	nor_write_byte(FLASH_INS_REN);

	chip_disable();

	wait_for_oip_to_clear();
}


void nor_flash::unlock_all_sectors(void)
{
	write_register(FLASH_INS_WRSR, 0);
}


void nor_flash::bulk_erase(void)
{
	uint8_t value = 0xFF;

	write_enable();

	do
	{
		osDelay(1);
		value = read_register(FLASH_INS_RDSR);

	}while(( value & 0x02) != 0x02);

	chip_enable();

	nor_write_byte(FLASH_INS_BE);

	chip_disable();
	wait_for_oip_to_clear();

	write_disable();
}


void nor_flash::sector_erase(uint32_t sector_address)
{
	write_enable();
	wait_for_oip_to_clear();

	chip_enable();

	nor_write_byte(FLASH_INS_SE4BYTE);
	nor_write_byte((sector_address & ADDRESS_BMASK3) >> 24);
	nor_write_byte((sector_address & ADDRESS_BMASK2) >> 16);
	nor_write_byte((sector_address & ADDRESS_BMASK1) >> 8);
	nor_write_byte(sector_address & ADDRESS_BMASK0);

	chip_disable();
	wait_for_oip_to_clear();
	write_disable();
}


