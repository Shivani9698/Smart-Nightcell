uint8_t device_info_t::update(void)
{
	uint8_t res = 0;

	res = eeprom.store_device_info((uint8_t *)&write_device_info, sizeof(device_info_t));

	return res;
}

void device_info_t::get(void)
{
	uint8_t res = eeprom.get_device_info((uint8_t *)&read_device_info, sizeof(device_info_t));
}

void device_info_t::device_reboot(void)
{
    __disable_irq();
    HAL_NVIC_SystemReset();
}


void doubleToString(double value, char* buffer, int precision)
{
  if (value < 0)
  {
    *buffer++ = '-';
    value = -value;
  }

  long intPart = (long)value;

  double frac = value - (double)intPart;
  long fracPart = (long)(frac * pow(10, precision) + 0.5);

  char temp[20];
  sprintf(temp, "%ld.%0*ld", intPart, precision, fracPart);
  strcpy(buffer, temp);
}


uint8_t process_battery_voltage(void)
{
	uint8_t battery_percentage = 0;
	uint8_t battery_voltage = 0;

    char* token = strtok((char *)voltage_sensor_processing_data_buffer, "V.D'\n");
    uint8_t count = 0;

    while (token != NULL)
    {
    	count++;

    	if (1 == count)
    	{
    		battery_voltage = atoi(token);
    	}

        token = strtok(NULL, "V.D'\n");
    }

    battery_percentage = (battery_voltage/VEHICLE_BATTERY_PEAK_VOLTAGE) * 100;

    return battery_percentage;
}



void voltage_sensor_rx_callback(UART_HandleTypeDef *huart)
{
	voltage_sensor_rx_byte = voltage_sensor.huart->Instance->RDR;

	if (voltage_sensor_rx_byte_counter >= 16)
	{
		memset(&voltage_sensor_data_buffer, 0, sizeof(voltage_sensor_data_buffer));
		voltage_sensor_rx_byte_counter = 0;
	}

	else if (voltage_sensor_rx_byte == 0)
	{

	}

	else if ((voltage_sensor_rx_byte == '\n') && (voltage_sensor_rx_byte_counter <= 9))
	{
		voltage_sensor_data_buffer[voltage_sensor_rx_byte_counter++] = voltage_sensor_rx_byte;
		voltage_sensor_data_buffer[voltage_sensor_rx_byte_counter++] = '\0';

		memset(&voltage_sensor_processing_data_buffer, 0, sizeof(voltage_sensor_processing_data_buffer));
		memcpy(voltage_sensor_processing_data_buffer, voltage_sensor_data_buffer, voltage_sensor_rx_byte_counter);

		voltage_sensor_isr_semaphore.acquire(0);
		voltage_sensor_isr_semaphore.release();
	}

	else if ((voltage_sensor_rx_byte == '\n') && (voltage_sensor_rx_byte_counter > 9))
	{
		memset(&voltage_sensor_data_buffer, 0, sizeof(voltage_sensor_data_buffer));
		voltage_sensor_rx_byte_counter = 0;
	}

	else
	{
		voltage_sensor_data_buffer[voltage_sensor_rx_byte_counter++] = voltage_sensor_rx_byte;
	}

	voltage_sensor.enable_interrupt();
}
