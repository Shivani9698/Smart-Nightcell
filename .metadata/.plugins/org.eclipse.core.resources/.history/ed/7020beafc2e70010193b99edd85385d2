mutex_t adc_mutex ((char *)"adc_mutex");



mutex_t::mutex_t(char * mutex_name)
{
	osMutexDef(myMutexID);
	myMutexID = osMutexCreate(osMutex(myMutexID));
}

mutex_t::~mutex_t()
{

}


uint8_t mutex_t::lock(uint32_t timeout)
{
	if(osMutexWait(myMutexID, timeout) == osOK)
	{
		return 1;
	}
	else
	{
		return 0;
	}
}


void mutex_t::unlock(void)
{
	osMutexRelease(myMutexID);
}

