uint8_t lorawan_params_t::parse_get_time_ack_packet(void)
{
	uint8_t result = 0;

	DynamicJsonDocument doc(128);

	DeserializationError error = deserializeJson(doc, data_rx_processing_buffer);

	if (error)
	{
		result = 0;
	}
	else
	{
		const char* command = doc["command"]; // "GET_TIME_ACK"
		long epoch_time = doc["epoch_time"]; // 1767362049

		debug.printf("time received: %ld\r\n", epoch_time);

		if ((epoch_time > JANUARY_1_2025_EPOCH_TIME) && (epoch_time < JANUARY_1_2050_EPOCH_TIME))
		{
			rtc.set_time_in_utc(epoch_time);

			result = 1;
		}
	}

	return result;
}


