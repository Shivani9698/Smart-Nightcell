uint16_t lorawan_params_t::serialize_connect_to_lorawan_network_packet(char * uplink_buffer, uint16_t size)
{
    DynamicJsonDocument doc(1024);

    doc["command"] = "CONNECT_TO_LORAWAN_NETWORK";
    doc["lorawan_app_key"] = read_device_info.lorawan_app_key;
    doc["lorawan_nwk_key"] = read_device_info.lorawan_nwk_key;
    doc["lorawan_app_session_key"] = read_device_info.lorawan_app_session_key;
    doc["lorawan_nwk_session_key"] = read_device_info.lorawan_nwk_session_key;
    doc["lorawan_device_eui"] = read_device_info.lorawan_device_eui;
    doc["lorawan_join_eui"] = read_device_info.lorawan_join_eui;
    doc["lorawan_device_address"] = read_device_info.lorawan_device_address;

    serializeJson(doc, uplink_buffer, size);

	uint16_t length = strlen(uplink_buffer);

	return length;
}


uint16_t lorawan_params_t::serialize_get_time_packet(char * uplink_buffer, uint16_t size)
{
	DynamicJsonDocument doc(64);

	doc["command"] = "GET_TIME";

    serializeJson(doc, uplink_buffer, size);

	uint16_t length = strlen(uplink_buffer);

	return length;
}



