lorawan_params_t::lorawan_params_t(UART_HandleTypeDef * uart, mutex_t& m, GPIO_TypeDef *lora_chip_reset_port, uint16_t lora_chip_reset_pin_number) :
	usart(uart, m), mutex(m), gpio(lora_chip_reset_port, lora_chip_reset_pin_number)
{

}


lorawan_params_t::~lorawan_params_t()
{

}


void lorawan_params_t::initialise(void)
{
	deinitialise();

	osDelay(250);

	on();
	init();
	register_rx_callback(lorawan_params_t::my_callback);
	enable_interrupt();
}


void lorawan_params_t::deinitialise(void)
{
	deinit();
	off();
	unregister_rx_callback();
}


uint8_t lorawan_params_t::send_command_and_wait_for_response(char * buffer, uint16_t length, uint32_t time_out)
{
	lorawan_command_response = invalid;

	uint32_t prev_time_in_millisec = HAL_GetTick();
	printf("%s\r\n", buffer);
	uint32_t current_time_in_millisec = HAL_GetTick();

	while((lorawan_command_response == invalid) && ((current_time_in_millisec - prev_time_in_millisec) < time_out))
	{
		current_time_in_millisec = HAL_GetTick();
		osDelay(10);
	}

	return lorawan_command_response;
}

uint8_t lorawan_params_t::send_packet_and_wait_for_response(uint8_t * buffer, uint16_t length, uint32_t time_out)
{
	lorawan_command_response = invalid;

	uint32_t prev_time_in_millisec = HAL_GetTick();
	send_bytes(buffer, length);
	uint32_t current_time_in_millisec = HAL_GetTick();

	while((lorawan_command_response == invalid) && ((current_time_in_millisec - prev_time_in_millisec) < time_out))
	{
		current_time_in_millisec = HAL_GetTick();
		osDelay(10);
	}

	return lorawan_command_response;
}


