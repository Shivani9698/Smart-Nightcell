uint32_t lorawan_thread_timeout_in_sec = 1;
uint32_t lorawan_connection_retry_counter = 0;
uint32_t lorawan_connection_backoff_in_sec = 3600; // 1 hour


void lorawan_params_t::process_lorawan_data(void)
{
	uint8_t result = 0;
	lorawan_command_response = invalid;

	if (strstr((char *)data_rx_processing_buffer, "LORAWAN_APPLICATION_RESET") != NULL)
	{
		lorawan.reboot_required = 0;
		lorawan.retry_counter = 0;

		lorawan.ready_status = 0;
		lorawan.connection_status = 0;
		lorawan.time_status = 0;
	}

	else if (strstr((char *)data_rx_processing_buffer, "READY_ACK") != NULL)
	{
		ready_status = 1;
		lorawan_command_response = received_ready;

		lorawan_connection_retry_counter = 0;

		debug.printf("READY_ACK received from stm32wl\r\n");
	}

	else if (strstr((char *)data_rx_processing_buffer, "CONNECT_TO_LORAWAN_NETWORK_NACK") != NULL)
	{
		lorawan_command_response = ttn_connection_fail;

		debug.printf("CONNECT_TO_LORAWAN_NETWORK_NACK received from stm32wl\r\n");

//		retry_counter++; // TODO: check if this is useful here because after timeout I'm resetting the device

		lorawan_connection_retry_counter++;

		if (lorawan_connection_retry_counter > LORAWAN_MAX_RETRY_JOIN_ATTEMPTS)
		{
			lorawan_connection_retry_counter = 0;

			lorawan.reboot_required = 1;

			debug.printf("lorawan max retry join attempts exceeded....rebooting\r\n");
		}
	}

	else if (strstr((char *)data_rx_processing_buffer, "CONNECT_TO_LORAWAN_NETWORK_ACK") != NULL)
	{
		debug.printf("CONNECT_TO_LORAWAN_NETWORK_ACK received from stm32wl\r\n");

		result = parse_connect_to_lorawan_network_ack_packet();

		if (1 == result)
		{
			lorawan_command_response = ttn_connection_success;

			lorawan_connection_retry_counter = 0;

			ready_status = 1;
			connection_status = 1;

//			lorawan_thread_timeout_in_sec = 10;
		}
		else
		{
			retry_counter++;
		}
	}

	else if (strstr((char *)data_rx_processing_buffer, "GET_TIME_ACK") != NULL) // TODO: handle time nack and increment retry counter
	{
		result = parse_get_time_ack_packet();

		if (1 == result)
		{
			lorawan_command_response = time_sync_success;

			blue_led.on();

			ready_status = 1;
			connection_status = 1;
			time_status = 1;

			rtc.date_time_saved = 1;

			if (1 == power_up)
			{
				write_device_info.device_start_time = rtc.get_time_in_utc();

				write_device_info.update();
				osDelay(100);
				read_device_info.get();

				power_up = 0;
			}
		}

		else
		{
			retry_counter++;
		}
	}

	else if (strstr((char *)data_rx_processing_buffer, "UPLINK_PAYLOAD_TX_ACK") != NULL)
	{
		debug.printf("UPLINK_PAYLOAD_TX_ACK received from stm32wl\r\n");

		result = parse_uplink_payload_tx_ack_packet();

		if (1 == result)
		{
			lorawan_command_response = publish_success;
		}
	}

	else if (strstr((char *)data_rx_processing_buffer, "UPLINK_PAYLOAD_TX_NACK") != NULL)
	{
		lorawan_command_response = publish_fail;
	}

	else if (strstr((char *)data_rx_processing_buffer, "TxTimer uplink BUSY") != NULL)
	{
		retry_counter++;
	}

	else if ((GENERALIZED_DATA_PAYLOAD_START_BYTE == data_rx_processing_buffer[0]) && (DOWNLINK_PACKET_TYPE == data_rx_processing_buffer[1]))
	{
		debug.printf("lorawan rx data: ");

		for (uint8_t i = 0 ; i < data_rx_processing_buffer[2] + DATA_HEADER_LENGTH ; i++)
		{
			debug.printf("%02X", data_rx_processing_buffer[i]);
		}
		debug.printf("\r\n");
	}

	else
	{

	}
}


void lorawan_thread_task(void const * argument)
{
  /* USER CODE BEGIN lorawan_thread_task */

	osDelay(5000);


  /* Infinite loop */
  for(;;)
  {
	  HAL_IWDG_Refresh(&hiwdg1);

	  if ((lorawan_enable == read_device_info.communication_mode_enabled) && (1 == peripherals.power_on_all_peripherals))
	  {
		  if (1 == lorawan.reboot_required)
		  {
			  debug.printf("Max lorawan retry count exceeded......Rebooting now\r\n");

			  lorawan.reboot_required = 0;
			  lorawan.retry_counter = 0;


			  lorawan.ready_status = 0;
			  lorawan.connection_status = 0;
			  lorawan.time_status = 0;

			  lorawan.initialise();
		  }


		  else if ((0 == lorawan.ready_status) && (0 == lorawan.connection_status) && (0 == lorawan.time_status))
		  {
			  uint16_t len = lorawan.serialize_ready_packet((char *)lorawan.data_tx_buffer, sizeof(lorawan.data_tx_buffer));

			  if (len > 0)
			  {
				  debug.printf("stm tx data: %s\r\n", lorawan.data_tx_buffer);
				  osDelay(500);
//				  lorawan.printf("%s\r\n", lorawan.data_tx_buffer);
				  lorawan.send_command_and_wait_for_response((char *)lorawan.data_tx_buffer, strlen((char *)lorawan.data_tx_buffer), (DATA_PAYLOAD_TIMEOUT_IN_SEC * 1000));
			  }
		  }

		  else if ((1 == lorawan.ready_status) && (0 == lorawan.connection_status) && (0 == lorawan.time_status))
		  {
			  uint16_t len = lorawan.serialize_connect_to_lorawan_network_packet((char *)lorawan.data_tx_buffer, sizeof(lorawan.data_tx_buffer));

			  if (len > 0)
			  {
				  debug.printf("stm tx data: %s\r\n", lorawan.data_tx_buffer);
				  osDelay(500);
//				  lorawan.printf("%s\r\n", lorawan.data_tx_buffer);
				  uint8_t result = lorawan.send_command_and_wait_for_response((char *)lorawan.data_tx_buffer, strlen((char *)lorawan.data_tx_buffer), (DATA_PAYLOAD_TIMEOUT_IN_SEC * 1000));

				  if(ttn_connection_success != result)
				  {
					  lorawan_thread_timeout_in_sec = (lorawan_thread_timeout_in_sec * 2 <= lorawan_connection_backoff_in_sec) ?
								lorawan_thread_timeout_in_sec * 2 : lorawan_connection_backoff_in_sec;
				  }
				  else if(ttn_connection_success == result)
				  {
					  lorawan_thread_timeout_in_sec = 1;
				  }
			  }
		  }

		  else if ((1 == lorawan.ready_status) && (1 == lorawan.connection_status) && (0 == lorawan.time_status))
		  {
			  uint16_t len = lorawan.serialize_get_time_packet((char *)lorawan.data_tx_buffer, sizeof(lorawan.data_tx_buffer));

			  if (len > 0)
			  {
				  debug.printf("stm tx data: %s\r\n", lorawan.data_tx_buffer);
				  osDelay(500);
//				  lorawan.printf("%s\r\n", lorawan.data_tx_buffer);
				  lorawan.send_command_and_wait_for_response((char *)lorawan.data_tx_buffer, strlen((char *)lorawan.data_tx_buffer), (DATA_PAYLOAD_TIMEOUT_IN_SEC * 1000));
			  }
		  }

		  else if ((1 == lorawan.ready_status) && (1 == lorawan.connection_status) && (1 == lorawan.time_status))
		  {
			  blue_led.toggle();

			  if (0 == peripherals.start_application)
			  {
				  peripherals.start_application = 1;
			  }

			  memset(lorawan.data_tx_buffer, 0, sizeof(lorawan.data_tx_buffer));
			  uint16_t length = check_if_any_uplink_to_be_published((char *)lorawan.data_tx_buffer, sizeof(lorawan.data_tx_buffer));

			  if (length > 0)
			  {
				  debug.printf("here........stm tx data: ");

				  for (uint8_t i = 0 ; i < length ; i++)
				  {
					  debug.printf("%02X", lorawan.data_tx_buffer[i]);
				  }
				  debug.printf("\r\n");

				  lorawan.send_packet_and_wait_for_response(lorawan.data_tx_buffer, length, (DATA_PAYLOAD_TIMEOUT_IN_SEC * 1000));

				  if (publish_success == lorawan_command_response)
				  {
					  debug.printf("successfully published uplink packet\r\n");

					  uint8_t status = clear_next_message_flags();

					  if (1 == status)
					  {
						  osDelay(2000);
						  __disable_irq();

						  HAL_NVIC_SystemReset();
					  }
				  }
			  }
		  }

		  if ((1 == lorawan.ready_status) && (1 == lorawan.connection_status) && (1 == lorawan.time_status))
		  {
			  blue_led.toggle();

			  if (1 == cellular_mutex.lock(1000))
			  {
				  write_index = eeprom.read_int(START_ADDRESS_OF_WRITE_COUNTER_INDEX);
				  write_page_counter = eeprom.storage_counter_read(write_index);

				  read_index = eeprom.read_int(START_ADDRESS_OF_READ_COUNTER_INDEX);
				  read_page_counter = eeprom.reader_counter_read(read_index);

				  if(read_page_counter % FOUR_MILLION == 0)
				  {
					  read_index = read_page_counter / FOUR_MILLION;

					  eeprom.write_int(read_index , START_ADDRESS_OF_READ_COUNTER_INDEX);
				  }

				  if (read_page_counter < write_page_counter)
				  {
					  memset(&water_tank_read_data_buffer, 0, sizeof(water_tank_read_data_buffer));
					  nor.read_data_packets(water_tank_read_data_buffer);

					  memcpy(&water_tank_read_data, water_tank_read_data_buffer, sizeof(water_tank_read_data_buffer));

					  memset(lorawan.data_tx_buffer, 0, sizeof(lorawan.data_tx_buffer));
					  uint16_t length = serialize_water_tank_data_payload_packet((char *)lorawan.data_tx_buffer, sizeof(lorawan.data_tx_buffer));

					  if (length > 0)
					  {
						  debug.printf("stm tx data: ");

						  for (uint8_t i = 0 ; i < length ; i++)
						  {
							  debug.printf("%02X", lorawan.data_tx_buffer[i]);
						  }
						  debug.printf("\r\n");

						  lorawan.send_packet_and_wait_for_response(lorawan.data_tx_buffer, length, (DATA_PAYLOAD_TIMEOUT_IN_SEC * 1000));

						  if (publish_success == lorawan_command_response)
						  {
							  read_page_counter++;
							  eeprom.reader_counter_write(read_page_counter, read_index);
						  }
					  }
				  }

				  cellular_mutex.unlock();
			  }
		  }



		  if (lorawan.retry_counter >= MAX_LORAWAN_RETRY_COUNTER)
		  {
			  lorawan.reboot_required = 1;
		  }
	  }

//	  debug.printf("lorawan_thread_timeout_in_sec: %d\r\n", lorawan_thread_timeout_in_sec);
	  osDelay(lorawan_thread_timeout_in_sec * 1000);
  }
  /* USER CODE END lorawan_thread_task */
}


void lorawan_processing_task(void const * argument)
{
  /* USER CODE BEGIN lorawan_processing_task */
  /* Infinite loop */
  for(;;)
  {
	  HAL_IWDG_Refresh(&hiwdg1);

	  if (1 == lorawan_isr_semaphore.acquire(1000))
	  {
		  lorawan.process_lorawan_data();
	  }

	  osDelay(1000);
  }
  /* USER CODE END lorawan_processing_task */
}



void lorawan_params_t::my_callback(UART_HandleTypeDef * uart)
{
	lorawan.rx_byte = lorawan.huart->Instance->RDR;

	if(lorawan.rx_counter >= (MAX_LORAWAN_BUFFER_SIZE - 4))
	{
		lorawan.rx_counter = 0;
	}

//	if(lorawan.rx_byte == 0) // TODO: check if this is necessary because, 0 can also be a part of the payload which is in hex format
//	{
//
//	}

	else if(lorawan.rx_byte == '\n')
	{
		lorawan.data_rx_buffer[lorawan.rx_counter++] = lorawan.rx_byte;

		if(lorawan.rx_counter > 6)
		{
			if (GENERALIZED_DATA_PAYLOAD_START_BYTE == lorawan.data_rx_buffer[0])
			{
				if (lorawan.rx_counter >= (lorawan.data_rx_buffer[2] + DATA_HEADER_LENGTH))
				{
					memset(lorawan.data_rx_processing_buffer, 0, sizeof(lorawan.data_rx_processing_buffer));
					memcpy(lorawan.data_rx_processing_buffer, lorawan.data_rx_buffer, lorawan.rx_counter);

					lorawan.rx_counter = 0;

					lorawan_isr_semaphore.acquire(0);
					lorawan_isr_semaphore.release();
				}
			}

			else
			{
				lorawan.data_rx_buffer[lorawan.rx_counter++] = '\0';

				memset(lorawan.data_rx_processing_buffer, 0, sizeof(lorawan.data_rx_processing_buffer));
				memcpy(lorawan.data_rx_processing_buffer, lorawan.data_rx_buffer, lorawan.rx_counter);

				lorawan.rx_counter = 0;

				lorawan_isr_semaphore.acquire(0);
				lorawan_isr_semaphore.release();
			}
		}

		else
		{
			lorawan.rx_counter = 0;
		}

	}

	else
	{
		lorawan.data_rx_buffer[lorawan.rx_counter++] = lorawan.rx_byte;
	}

	HAL_UART_Receive_IT(lorawan.huart, (uint8_t *)&lorawan.usart_rx_byte, 1);
}
