uint16_t check_if_any_uplink_to_be_published(char * uplink_buffer, uint16_t size)
{
	uint16_t length = 0;

	if (1 == next_message.https_error_message)
	{
		length = serialize_https_error_message(uplink_buffer, size);
	}

	else if (1 == next_message.start_up)
	{
		length = serialize_startup_packet(uplink_buffer, size);
	}

	else if (1 == next_message.health)
	{
		length = serialize_health_packet(uplink_buffer, size);
	}

	else if (1 == next_message.set_config_ack)
	{
		length = serialize_set_config_ack_packet(uplink_buffer, size);
	}

	else if (1 == next_message.get_config_ack)
	{
		length = serialize_get_config_ack_packet(uplink_buffer, size);
	}

	else if (1 == next_message.configure_apn_ack)
	{
		length = serialize_configure_apn_ack_packet(uplink_buffer, size);
	}

	else if (1 == next_message.reboot_ack)
	{
		length = serialize_reboot_ack_packet(uplink_buffer, size);
	}

	else if (1 == next_message.reset_to_factory_defaults_ack)
	{
		length = serialize_reset_to_factory_defaults_ack_packet(uplink_buffer, size);
	}

	else if (1 == next_message.turn_off_edge_device_ack)
	{
		length = serialize_turn_off_edge_device_ack_packet(uplink_buffer, size);
	}

	else if (1 == next_message.set_lorawan_config_ack)
	{
		length = serialize_set_lorawan_config_ack_packet(uplink_buffer, size);
	}


//	if (length > 0)
//	{
//		debug.printf("stm tx data: %s\r\n", wifi.uplink_message_buffer);
//		wifi.printf(wifi.uplink_message_buffer);
//	}

	return length;
}
