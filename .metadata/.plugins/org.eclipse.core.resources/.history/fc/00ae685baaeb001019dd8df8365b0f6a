next_message_to_send_t next_message;




next_message_to_send_t::next_message_to_send_t(void)
{

}

next_message_to_send_t::~next_message_to_send_t(void)
{

}

uint8_t next_message_to_send_t::load_default_values(void)
{
	memset(&next_message, 0, sizeof(next_message));

	uint8_t res = update();

	return res;
}

uint8_t next_message_to_send_t::update(void)
{
	uint8_t res = eeprom.store_next_message_to_send_info((uint8_t *)&next_message, sizeof(next_message));

	return res;
}

void next_message_to_send_t::get(void)
{
	eeprom.get_next_message_to_send_info((uint8_t *)&next_message, sizeof(next_message));
}




uint16_t serialize_https_error_message(char * uplink_buffer, uint16_t size)
{
	DynamicJsonDocument doc(256);

	doc["command"] = "HTTPS_ERROR_MESSAGE";
	doc["device_id"] = read_device_info.device_id;
	doc["epoch_time"] = rtc.get_time_in_utc();
	doc["error_code"] = lte.https_error_code;
	doc["error_message"] = lte.https_error_message_buffer;

	serializeJson(doc, uplink_buffer, size);

	uint16_t length = strlen(uplink_buffer);

	return length;
}



uint16_t serialize_startup_packet(char * uplink_buffer, uint16_t size)
{
	DynamicJsonDocument doc(1024);

	doc["command"] = "STARTUP_MESSAGE";
	doc["device_id"] = read_device_info.device_id;
	doc["reboot_reason"] = reset_cause_get_name(device_reset_reason);

	if (1 == power_status)
	{
		doc["device_power_source"] = "mains";
	}
	else
	{
		doc["device_power_source"] = "battery";
	}

	doc["device_battery_percentage"] = present_battery_percentage;
	doc["epoch_time"] = rtc.get_time_in_utc();
	doc["sampling_frequency"] = read_device_info.data_sampling_frequency_in_sec;
	doc["wifi_enabled"] = peripherals.wifi_enable;
	doc["mac_id"] = read_device_info.device_id;
	doc["connected_ap_ssid"] = read_device_info.ssid;
	doc["connected_ap_password"] = read_device_info.password;
	doc["ip_address"] = read_device_info.ap_static_ip;
	doc["cellular_enabled"] = peripherals.cellular_enable;
	doc["imei"] = read_device_info.sim_imei_number;
	doc["ccid"] = read_device_info.sim_ccid_number;
	doc["signal_strength"] = lte.received_signal_power;
	doc["lorawan_enabled"] = peripherals.lorawan_enable;
	doc["device_eui"] = read_device_info.lorawan_device_eui;
	doc["join_eui"] = read_device_info.lorawan_join_eui;
	doc["gps_enabled"] = peripherals.gps_enable;
	doc["lbs_enabled"] = peripherals.lbs_enable;
	doc["hardware_version"] = read_device_info.hw_ver;
	doc["firmware_version"] = read_device_info.fw_ver;
	doc["reserved_1"] = "reserved_1_value";
	doc["reserved_2"] = "reserved_2_value";
	doc["reserved_3"] = "reserved_3_value";

	serializeJson(doc, uplink_buffer, size);

	uint16_t length = strlen(uplink_buffer);

