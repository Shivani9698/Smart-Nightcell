void string_to_hex(const char* str, uint8_t* holder, uint8_t size)
{
    if (str != NULL && holder != NULL)
    {
		size_t len = strlen(str);

		for (uint8_t i = 0 ; i < size ; i++)
		{
			if (i * 2 + 1 < len)
			{
				char byteString[3];

				byteString[0] = str[i * 2];
				byteString[1] = str[i * 2 + 1];
				byteString[2] = '\0';

				holder[i] = (uint8_t)strtol(byteString, NULL, 16);
			}
			else
			{
				holder[i] = 0;
			}
		}
    }
}





uint16_t serialize_water_tank_data_payload_packet(char * uplink_buffer, uint16_t size)
{
	uint16_t length = 0;
	char processing_buffer[16] = "";

	if ((0 == peripherals.lorawan_enable) && (lorawan_enable != read_device_info.communication_mode_enabled))
	{
		DynamicJsonDocument doc(256);

		doc["command"] = "DATA_PAYLOAD";
		doc["device_id"] = water_tank_read_data.device_id;
		doc["device_power_source"] = water_tank_read_data.device_power_source;// "mains";
		doc["device_battery_percentage"] = water_tank_read_data.device_battery_percentage;
		doc["sample_packet_number"] = water_tank_read_data.packet_number;
		doc["epoch_time"] = water_tank_read_data.sample_epoch_time;
		doc["sampling_frequency"] = read_device_info.data_sampling_frequency_in_sec;
		doc["water_level"] = water_tank_read_data.water_level_in_percentage;

		serializeJson(doc, uplink_buffer, size);
	}

	else if ((1 == peripherals.lorawan_enable) && (lorawan_enable == read_device_info.communication_mode_enabled))
	{
		uplink_buffer[0] = 0xAA;
		uplink_buffer[1] = 01;
		uplink_buffer[2] = 0x17;
		uplink_buffer[3] = 0xA9;

//		string_to_hex(water_tank_read_data.device_id, (uint8_t *)processing_buffer, 8); // TODO: what if the actual device-id more than 8 bytes so use lorawan device_eui instead of device-id
		string_to_hex(read_device_info.lorawan_device_eui, (uint8_t *)processing_buffer, 8); // TODO: what if the actual device-id more than 8 bytes so use lorawan device_eui instead of device-id

		memcpy(&uplink_buffer[4], processing_buffer, 8);

		if (strstr(water_tank_read_data.device_power_source, "mains") != NULL)
		{
			uplink_buffer[12] = 1;
		}
		else
		{
			uplink_buffer[12] = 0;
		}

		uplink_buffer[13] = water_tank_read_data.device_battery_percentage;

		memcpy(&uplink_buffer[14], &water_tank_read_data.packet_number, 4);

		memcpy(&uplink_buffer[18], &water_tank_read_data.sample_epoch_time, 4);

		memcpy(&uplink_buffer[22], &read_device_info.data_sampling_frequency_in_sec, 2);

		memcpy(&uplink_buffer[24], &water_tank_read_data.water_level_in_percentage, 2);
	}


	length = strlen(uplink_buffer);

	return length;
}



