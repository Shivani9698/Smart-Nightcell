#ifndef SRC_EXTERNAL_EEPROM_H_
#define SRC_EXTERNAL_EEPROM_H_


#include "main.h"
#include "i2c.h"
#include "includes.h"



#define	FOUR_MILLION										4194304

#define EEPROM_DEVICE_ADDRESS								0xAC
#define EEPROM_MEMORY_SIZE 									(128 * 1024)
#define EEPROM_PAGE_SIZE									256
