#define START_ADDRESS_OF_READ_COUNTER						0
#define END_ADDRESS_OF_READ_COUNTER  						256

#define START_ADDRESS_OF_WRITE_COUNTER						256
#define END_ADDRESS_OF_WRITE_COUNTER  						512

#define START_ADDRESS_OF_MESSAGE_COUNTER					512
#define END_ADDRESS_OF_MESSAGE_COUNTER  					768


#define START_ADDRESS_OF_READ_COUNTER_INDEX					768
#define END_ADDRESS_OF_READ_COUNTER_INDEX 					772

#define START_ADDRESS_OF_WRITE_COUNTER_INDEX				772
#define END_ADDRESS_OF_WRITE_COUNTER_INDEX  				776

#define START_ADDRESS_OF_MESSAGE_COUNTER_INDEX				776
#define END_ADDRESS_OF_MESSAGE_COUNTER_INDEX  				780





#define START_ADDRESS_OF_DEVICE_INFO						4096
#define SIZE_OF_DEVICE_INFO									2048
#define END_ADDRESS_OF_DEVICE_INFO							6144


#define START_ADDRESS_OF_WIFI_CREDENTIALS					6144
#define SIZE_OF_WIFI_CREDENTIALS							1024
#define EDN_ADDRESS_OF_WIFI_CREDENTIALS						7168


#define START_ADDRESS_OF_PERIPHERAL_CONFIG					7168
