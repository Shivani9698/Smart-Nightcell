#define START_ADDRESS_OF_NEXT_MESSAGE_TO_SEND				8192
#define SIZE_OF_NEXT_MESSAGE_TO_SEND						512
#define END_ADDRESS_OF_NEXT_MESSAGE_TO_SEND					8704



class external_eeprom : public i2c
{
	public:
		uint16_t device_address;

		external_eeprom(I2C_HandleTypeDef * i2c_handler, uint16_t device_address);
		virtual ~external_eeprom();

		void erase_eeprom(void);

		void write_byte(uint8_t value, uint16_t address);
		uint8_t read_byte(uint16_t address);

		void write_int(int value, uint16_t address);
		uint32_t read_int(uint16_t address);

		uint8_t write_structure( uint8_t * write_data, uint16_t address, uint16_t length);
		uint8_t read_structure(uint8_t * read_values, uint16_t address, uint16_t length);



		void storage_counter_write(uint32_t value, uint16_t index);
		uint32_t storage_counter_read( uint16_t index);

		void reader_counter_write(uint32_t value,  uint16_t index);
		uint32_t reader_counter_read( uint16_t index);

		uint32_t message_counter_read( uint16_t index);
		void message_counter_write(uint32_t value, uint16_t index);



		uint8_t store_device_info(uint8_t* write_data, uint16_t length);
		uint8_t get_device_info(uint8_t* read_data, uint16_t length);


		uint8_t store_wifi_credentials_info(uint8_t* write_data, uint16_t length);
		uint8_t get_wifi_credentials_info(uint8_t* read_data, uint16_t length);


		uint8_t store_peripheral_configuration_info(uint8_t* write_data, uint16_t length);
		uint8_t get_peripheral_configuration_info(uint8_t* read_data, uint16_t length);


		uint8_t store_next_message_to_send_info(uint8_t* write_data, uint16_t length);
		uint8_t get_next_message_to_send_info(uint8_t* read_data, uint16_t length);
};

extern external_eeprom eeprom;



extern uint32_t write_index;
extern uint32_t write_counter;

extern uint32_t read_index;
extern uint32_t read_page_counter;

extern uint32_t message_counter;
extern uint32_t message_counter_index;


extern uint32_t write_page_counter;

#endif /* SRC_EXTERNAL_EEPROM_H_ */

