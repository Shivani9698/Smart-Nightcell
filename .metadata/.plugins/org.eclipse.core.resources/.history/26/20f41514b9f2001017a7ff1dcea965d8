		length = serialize_get_config_ack_packet(uplink_buffer, size);
	}

	else if (1 == next_message.configure_apn_ack)
	{
		length = serialize_configure_apn_ack_packet(uplink_buffer, size);
	}

	else if (1 == next_message.reboot_ack)
	{
		length = serialize_reboot_ack_packet(uplink_buffer, size);
	}

	else if (1 == next_message.reset_to_factory_defaults_ack)
	{
		length = serialize_reset_to_factory_defaults_ack_packet(uplink_buffer, size);
	}

	else if (1 == next_message.turn_off_edge_device_ack)
	{
