		doc["epoch_time"] = rtc.get_time_in_utc();
		doc["lorawan_app_key"] = read_device_info.lorawan_app_key;
		doc["lorawan_nwk_key"] = read_device_info.lorawan_nwk_key;
		doc["lorawan_app_session_key"] = read_device_info.lorawan_app_session_key;
		doc["lorawan_nwk_session_key"] = read_device_info.lorawan_nwk_session_key;
		doc["lorawan_device_eui"] = read_device_info.lorawan_device_eui;
		doc["lorawan_join_eui"] = read_device_info.lorawan_join_eui;
		doc["lorawan_device_address"] = read_device_info.lorawan_device_address;

		serializeJson(doc, uplink_buffer, size);

		length = strlen(uplink_buffer);
	}

	else if ((1 == peripherals.lorawan_enable) && (lorawan_enable == read_device_info.communication_mode_enabled))
	{
		uplink_buffer[0] = GENERALIZED_DATA_PAYLOAD_START_BYTE;
		uplink_buffer[1] = UPLINK_PACKET_TYPE;
		uplink_buffer[2] = SET_LORAWAN_CONFIG_ACK_PACKET_PAYLOAD_LENGTH;

		uplink_buffer[3] = SET_LORAWAN_CONFIG_ACK_PACKET_PAYLOAD_START_BYTE;

		string_to_hex(read_device_info.lorawan_device_eui, (uint8_t *)processing_buffer, 8); // TODO: what if the actual device-id more than 8 bytes so use lorawan device_eui instead of device-id
		memcpy(&uplink_buffer[4], processing_buffer, 8);


		uint32_t epoch = rtc.get_time_in_utc();

		uplink_buffer[12] = (epoch & 0xFF000000) >> 24;
		uplink_buffer[13] = (epoch & 0x00FF0000) >> 16;
		uplink_buffer[14] = (epoch & 0x0000FF00) >> 8;
		uplink_buffer[15] = epoch & 0xFF;


		string_to_hex(read_device_info.lorawan_app_key, (uint8_t *)processing_buffer, 16);
		memcpy(&uplink_buffer[16], processing_buffer, 16);

		string_to_hex(read_device_info.lorawan_nwk_key, (uint8_t *)processing_buffer, 16);
		memcpy(&uplink_buffer[32], processing_buffer, 16);

		string_to_hex(read_device_info.lorawan_app_session_key, (uint8_t *)processing_buffer, 16);
		memcpy(&uplink_buffer[48], processing_buffer, 16);

		string_to_hex(read_device_info.lorawan_nwk_session_key, (uint8_t *)processing_buffer, 16);
		memcpy(&uplink_buffer[64], processing_buffer, 16);

		string_to_hex(read_device_info.lorawan_device_eui, (uint8_t *)processing_buffer, 8);
		memcpy(&uplink_buffer[80], processing_buffer, 8);

		string_to_hex(read_device_info.lorawan_join_eui, (uint8_t *)processing_buffer, 8);
		memcpy(&uplink_buffer[88], processing_buffer, 8);

		string_to_hex(read_device_info.lorawan_device_address, (uint8_t *)processing_buffer, 4);
		memcpy(&uplink_buffer[96], processing_buffer, 4);

		uplink_buffer[100] = '\n';

		length = SET_LORAWAN_CONFIG_ACK_PACKET_PAYLOAD_LENGTH + DATA_HEADER_LENGTH + 1; // +1 because of '\n'

	}

	return length;
}


uint8_t clear_next_message_flags(void)
{
	uint8_t status = 0;

	if (1 == next_message.https_error_message)
	{
		next_message.https_error_message = 0;
	}

	else if (1 == next_message.start_up)
	{
		next_message.start_up = 0;
	}

	else if (1 == next_message.health)
	{
		next_message.health = 0;
	}

	else if (1 == next_message.set_config_ack)
	{
		next_message.set_config_ack = 0;

		status = 1;
	}

	else if (1 == next_message.get_config_ack)
	{
		next_message.get_config_ack = 0;
	}


	else if (1 == next_message.configure_apn_ack)
	{
		next_message.configure_apn_ack = 0;

		status = 1;
	}

	else if (1 == next_message.reboot_ack)
	{
		next_message.reboot_ack = 0;

		status = 1;
	}

	else if (1 == next_message.reset_to_factory_defaults_ack)
	{
		next_message.reset_to_factory_defaults_ack = 0;

		eeprom.write_byte(0xFE, START_ADDRESS_OF_NEW_EEPROM);

		status = 1;
	}

	else if (1 == next_message.turn_off_edge_device_ack)
	{
		next_message.turn_off_edge_device_ack = 0;

		peripherals.power_on_all_peripherals = 0;
	}

	else if (1 == next_message.set_lorawan_config_ack)
	{
		next_message.set_lorawan_config_ack = 0;
	}

	next_message.update();
	osDelay(100);
	next_message.get();

	return status;
}



