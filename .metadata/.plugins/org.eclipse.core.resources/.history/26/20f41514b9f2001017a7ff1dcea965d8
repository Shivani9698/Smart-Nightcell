		serializeJson(doc, uplink_buffer, size);

		length = strlen(uplink_buffer);
	}

	else if ((1 == peripherals.lorawan_enable) && (lorawan_enable == read_device_info.communication_mode_enabled))
	{
		uplink_buffer[0] = GENERALIZED_DATA_PAYLOAD_START_BYTE;
		uplink_buffer[1] = UPLINK_PACKET_TYPE;
		uplink_buffer[2] = CONFIGURE_APN_ACK_PACKET_PAYLOAD_LENGTH;

		uplink_buffer[3] = CONFIGURE_APN_ACK_PACKET_PAYLOAD_START_BYTE;

		string_to_hex(read_device_info.lorawan_device_eui, (uint8_t *)processing_buffer, 8); // TODO: what if the actual device-id more than 8 bytes so use lorawan device_eui instead of device-id

		memcpy(&uplink_buffer[4], processing_buffer, 8);


		uint32_t epoch = rtc.get_time_in_utc();

		uplink_buffer[12] = (epoch & 0xFF000000) >> 24;
		uplink_buffer[13] = (epoch & 0x00FF0000) >> 16;
		uplink_buffer[14] = (epoch & 0x0000FF00) >> 8;
		uplink_buffer[15] = epoch & 0xFF;


		uint8_t apn_len = strlen(write_device_info.apn);

